DATABASE_URL=postgresql://user:password@host:5432/tovapos
NEXT_PUBLIC_STORAGE_DRIVER=postgres
NEXT_PUBLIC_SITE_URL=https://your-tovapos-domain.example
NEXT_PUBLIC_APP_URL=https://your-tovapos-domain.example
RESEND_API_KEY=re_your_resend_api_key
PASSWORD_RESET_FROM_EMAIL="TOVAPOS <no-reply@your-domain.example>"
# Mailgun may be used instead of Resend.
MAILGUN_API_KEY=key-your_mailgun_api_key
MAILGUN_DOMAIN=mg.your-domain.example
MAILGUN_BASE_URL=https://api.mailgun.net
# Local development only. Never enable this in production.
PASSWORD_RESET_DEV_LINKS=false
AUTH_DEV_LINKS=false
CRON_SECRET=generate-a-random-secret-with-at-least-32-characters
EXPIRY_DIGEST_TIMEZONE=Africa/Lagos
DATABASE_POOL_MAX=10
DATABASE_CONNECT_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_QUERY_TIMEOUT_MS=20000

# Platform admin seed. Set these in Render environment variables.
PLATFORM_ADMIN_EMAIL=admin@your-domain.example
PLATFORM_ADMIN_NAME="TOVAPOS Super Admin"
PLATFORM_ADMIN_PASSWORD=replace-with-a-long-secret-password
